# Backend configuration (all variables are prefixed with APP_)
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated allowed origins.
# DEV: "*" is fine. PRODUCTION: set to your exact Vercel domain(s) so that only
# your official frontend can call the API from a browser, e.g.:
#   APP_ALLOWED_ORIGINS=https://veracity-bert-liar.vercel.app
APP_ALLOWED_ORIGINS=*

# Rate limiting (abuse prevention) — per client IP.
APP_RATE_LIMIT_PREDICT=30/minute
APP_RATE_LIMIT_DEFAULT=120/minute
APP_MAX_STATEMENT_CHARS=2000

# Logging
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=false

# Path to trained model weights (defaults to ../../models)
# APP_MODELS_DIR=/absolute/path/to/models

# Hugging Face Hub — auto-download weights on startup when absent locally
# (required for cloud deploys like Render where the .pt files are not in git).
# APP_HF_REPO_ID=adityarajmishra/veracity-bert-liar
# APP_HF_TOKEN=          # only needed if the HF repo is private

